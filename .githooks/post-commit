#!/usr/bin/env bash
# .githooks/post-commit
#
# Prepends a status entry to LEDGER.md and amends the triggering commit so
# the ledger update and the code change live in the same commit object.
#
# The --no-verify flag on the amend call prevents this hook from re-running.
#
# Activate once per clone:
#   git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
LEDGER="$REPO_ROOT/LEDGER.md"
DELIMITER="<!-- entries -->"

# ── collect commit metadata ──────────────────────────────────────────────────
HASH=$(git log -1 --pretty=format:"%h")
MSG=$(git log -1 --pretty=format:"%s")
BRANCH=$(git rev-parse --abbrev-ref HEAD)
AUTHOR=$(git log -1 --pretty=format:"%an")
TIMESTAMP=$(date '+%Y-%m-%d %H:%M')

# Files touched — cap display at 10, note overflow
ALL_FILES=$(git diff-tree --no-commit-id -r --name-only HEAD)
TOTAL=$(echo "$ALL_FILES" | grep -c '' || true)
SHOWN=$(echo "$ALL_FILES" | head -10)
FILE_LINES=$(echo "$SHOWN" | awk '{print "  - " $0}')
if [ "$TOTAL" -gt 10 ]; then
  FILE_LINES="${FILE_LINES}
  - …and $((TOTAL - 10)) more"
fi

# ── bootstrap ledger if it doesn't exist yet ────────────────────────────────
if [ ! -f "$LEDGER" ]; then
  cat > "$LEDGER" <<'HEADER'
# HealthyFlow — Project Ledger

Auto-updated on every commit. Newest entries appear first.

- GitHub Issues: https://github.com/lermanori/HealthyFlow/issues
- Kanban: https://github.com/users/lermanori/projects/1/views/1

<!-- entries -->
HEADER
fi

# Ensure delimiter exists in case someone edited the file
if ! grep -qF "$DELIMITER" "$LEDGER"; then
  printf '\n%s\n' "$DELIMITER" >> "$LEDGER"
fi

# ── build the new entry block ────────────────────────────────────────────────
ENTRY="### ${TIMESTAMP} — ${MSG}

- **Commit**: \`${HASH}\` · branch \`${BRANCH}\`
- **Author**: ${AUTHOR}
- **Files changed** (${TOTAL}):
${FILE_LINES}

---
"

# ── insert entry immediately after delimiter (newest first) ──────────────────
python3 - "$LEDGER" "$DELIMITER" "$ENTRY" <<'PYEOF'
import sys, pathlib

ledger_path = pathlib.Path(sys.argv[1])
delimiter   = sys.argv[2]
entry       = sys.argv[3]

text = ledger_path.read_text()

if delimiter not in text:
    text += f"\n{delimiter}\n"

before, after = text.split(delimiter, 1)
ledger_path.write_text(f"{before}{delimiter}\n\n{entry}\n{after.lstrip()}")
PYEOF

# ── amend the commit to include the ledger update ────────────────────────────
git -C "$REPO_ROOT" add "$LEDGER"
git -C "$REPO_ROOT" commit --amend --no-edit --no-verify
