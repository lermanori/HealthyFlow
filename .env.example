# Frontend environment (Vite)
#
# IMPORTANT: only PUBLIC values belong in committed env files (.env.example,
# .env.production). Every `VITE_`-prefixed var is inlined into the browser
# bundle at build time and is therefore world-readable. Never put server
# secrets (OpenAI keys, JWT secrets, Supabase service-role keys, VAPID private
# key) in a `VITE_` var or in any committed .env file. Server secrets live only
# on Railway / in the local, gitignored `.env`.

# Base URL of the backend API (public)
VITE_API_URL=

# Public VAPID key (same value as backend VAPID_PUBLIC_KEY), exposed to the browser
VITE_VAPID_PUBLIC_KEY=

# PostHog analytics (public ingest key + host)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
